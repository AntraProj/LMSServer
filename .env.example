# -------------------------------------------------------
# IMP INSTRUCTIONS
# -------------------------------------------------------
# Do not commit this file with real values. Create a copy named ".env" and fill in the values there.
# This is example env file, use this as a template for your actual .env file.
# Required fields = [NODE_ENV, DATABASE_URL, PORT, JWT_SECRET_KEY, CORS_ORIGINS]

# -------------------------------------------------------
# ENVIRONMENT
# -------------------------------------------------------
# Set to "production" or "development" or "test"
NODE_ENV=

# -------------------------------------------------------
# DATABASE
# -------------------------------------------------------
DATABASE_URL=
PORT=

# -------------------------------------------------------
# ADMIN USER
# Required for production seed only
# Generate password hash locally before deploying:
#   node -e "import('bcrypt').then(b => b.hash('yourpassword', 12).then(console.log))"
# -------------------------------------------------------
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_FULL_NAME=

# -------------------------------------------------------
# JWT
# -------------------------------------------------------
JWT_SECRET_KEY=
JWT_EXPIRES_IN=

# -------------------------------------------------------
# CORS
# CORS_ORIGINS should be a comma-separated list of allowed origins, e.g. "http://localhost:3000,http://example.com"
# -------------------------------------------------------
CORS_ORIGINS=

# -------------------------------------------------------
# LOGGING
# -------------------------------------------------------
LOG_LEVEL=
LOG_DIR=