# -------------------------------------------------------
# IMP INSTRUCTIONS
# -------------------------------------------------------
# Do not commit this file with real values. Create a copy named ".env" and fill in the values there.
# This is example env file, use this as a template for your actual .env file.

# -------------------------------------------------------
# ENVIRONMENT
# -------------------------------------------------------
# Set to "production" or "development"
NODE_ENV=

# -------------------------------------------------------
# DATABASE
# -------------------------------------------------------
DATABASE_URL=
PORT=

# -------------------------------------------------------
# ADMIN USER
# Required for production seed only
# Generate password hash locally before deploying:
#   node -e "import('bcrypt').then(b => b.hash('yourpassword', 12).then(console.log))"
# -------------------------------------------------------
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_FULL_NAME=

# -------------------------------------------------------
# JWT
# -------------------------------------------------------
JWT_SECRET_KEY=
JWT_EXPIRES_IN=